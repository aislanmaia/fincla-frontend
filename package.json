{
  "name": "fincla-frontend",
  "version": "2.0.0",
  "type": "module",
  "private": true,
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "biome lint src --diagnostic-level=error",
    "check": "npm run lint && tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:repeat": "sh -c 'for i in 1 2 3 4 5; do echo \"=== E2E $i/5 ===\" && npm run test:e2e || exit 1; done'",
    "test:e2e:install": "playwright install chromium"
  },
  "dependencies": {
    "@react-pdf/renderer": "^4.5.1",
    "@tanstack/react-router": "^1.168.23",
    "@tanstack/zod-adapter": "^1.166.9",
    "axios": "^1.13.2",
    "lucide-react": "^0.453.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.15.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "20.16.11",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.2",
    "jsdom": "^28.1.0",
    "typescript": "5.6.3",
    "vite": "^5.4.19",
    "vitest": "^4.1.0"
  }
}
