# Dev-mode overrides para apontar o SPA ao tunnel cloudflared.
#
# Carregado por Vite SOMENTE em `npm run dev` (modo "development") e tem
# prioridade sobre `.env.local`. Em build de produção (`npm run build`)
# este arquivo é ignorado — `.env.production` continua valendo.
#
# Pra desligar temporariamente (testar offline / sem tunnel), basta
# comentar as duas linhas abaixo; Vite cai pro `.env.local`.

VITE_API_BASE_URL=https://dev-api.fincla.com
VITE_APP_URL=https://dev.fincla.com.br
VITE_APP_NAME=Fincla
VITE_APP_VERSION=1.0.0
